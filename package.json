{
  "name": "checkmate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "auth:hash": "tsx scripts/hash-password.ts",
    "build": "tsc -b && vite build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev": "concurrently \"vite\" \"tsx watch --env-file-if-exists=.env server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch --env-file-if-exists=.env server/index.ts",
    "lint": "tsc -b && tsc -p tsconfig.server.json && eslint .",
    "prettier:ci": "pnpm exec prettier --check .",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "resolutions": {
    "esbuild": "^0.25.0",
    "ip-address": "^10.1.1"
  },
  "dependencies": {
