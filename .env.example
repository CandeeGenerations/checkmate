# Parent password (bcrypt hash). Generate via: pnpm auth:hash
AUTH_PASSWORD_HASH=

# JWT signing secret. Generate via: openssl rand -hex 32
JWT_SECRET=

# Optional. Defaults to 7d. Format: Nd | Nh | Nm
JWT_EXPIRY=7d

# Backend port (Express). Defaults to 5176.
PORT=5176

# ---------- Sentry ----------
# Env-var topology for cgen apps (see plans/sentry-integration.md):
#
#   - Per-project, runtime → launchd plist EnvironmentVariables
#       SENTRY_DSN_SERVER, SENTRY_ENVIRONMENT, SENTRY_RELEASE
#
#   - Per-project, build-time → this .env file (gitignored)
#       VITE_SENTRY_DSN, SENTRY_PROJECT_WEB
#       (Mirrored here so `pnpm dev` and `pnpm build` from a terminal pick
#        them up. scripts/deploy.sh also sources this file.)
#
#   - Org-level, build-time → ~/.zshrc (shared across every cgen project)
#       SENTRY_AUTH_TOKEN, SENTRY_ORG
#       (Do NOT put per-project DSNs or slugs in ~/.zshrc — they collide.)

# Per-project runtime (used by tsx-watched dev server, in absence of plist):
SENTRY_DSN_SERVER=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Per-project build-time (Vite reads VITE_* from this file automatically):
VITE_SENTRY_DSN=
SENTRY_PROJECT_WEB=checkmate-web
