#!/usr/bin/env bash
# Auto-deploy when a commit lands on main. Feature branch commits are skipped.
# Bypass with: SKIP_DEPLOY=1 git commit ...

if [[ -n "${SKIP_DEPLOY:-}" ]]; then
  echo "post-commit: SKIP_DEPLOY set, skipping deploy"
  exit 0
fi

BRANCH=$(git rev-parse --abbrev-ref HEAD)
if [[ "$BRANCH" != "main" ]]; then
  exit 0
fi

# Source .env.deploy if present — needed when invoked from GUI git clients
# (GitHub Desktop, Tower, etc.) that don't inherit the user's shell env.
# scripts/deploy.sh sources the per-project .env separately for build vars.
REPO_ROOT="$(git rev-parse --show-toplevel)"
if [[ -f "$REPO_ROOT/.env.deploy" ]]; then
  # shellcheck disable=SC1091
  source "$REPO_ROOT/.env.deploy"
fi

echo "post-commit: on main → running deploy"
"$REPO_ROOT/scripts/deploy.sh"
